# Start date of the first period (format: YYYY-MM-DD HH:MM:SS)
START_DATE=2026-01-01 00:00:00 # TODO: set this to the start date of your first period

# Absolute path to the git repository to track
REPO_DIR=/Users/name/dev/paper # TODO: set this to the absolute path of your git repository

# Path to the LaTeX file to track (relative to REPO_DIR)
FILE_PATH=main.tex

# Output CSV filename
CSV_OUT=progress.csv

# Minimum characters required per period
MIN_CHARS=1000

# Length of each tracking period in days (7 = weekly, 14 = biweekly, 30 = monthly)
INTERVAL_DAYS=7
